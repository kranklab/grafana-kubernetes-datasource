# Copy this file to .env.test.local and fill in real values.
# Source it before running the EKS integration tests:
#
#   source .env.test.local
#   go test ./pkg/plugin/ -run TestEKS -v
#
# URL and CA cert are fetched automatically via DescribeCluster — no need to set them manually.

# Required for all EKS tests
TEST_AWS_REGION=
TEST_EKS_CLUSTER_NAME=

# IAM user credentials (required for TestEKSIAMUser)
TEST_AWS_ACCESS_KEY_ID=
TEST_AWS_SECRET_ACCESS_KEY=

# IAM role (required for TestEKSIAMRole)
TEST_AWS_ROLE_ARN=             # arn:aws:iam::123456789012:role/my-role
TEST_AWS_EXTERNAL_ID=          # optional
# Leave access key vars above empty to use default credential chain for role tests
